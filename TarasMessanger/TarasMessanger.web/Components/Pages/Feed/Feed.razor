@page "/feed"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using TarasMessanger.Core.DTOs.Posts
@using TarasMessanger.Services
@using TarasMessanger.Storage.Identity
@using TarasMessanger.web.Components.UiComponents.Posts
@using TarasMessanger.web.Services

@rendermode InteractiveServer

@inject PostService PostService;
@inject PostMediaStorage PostMediaStorage;
@inject UserManager<ApplicationUser> UserManager;
@inject NavigationManager NavigationManager;

@attribute [Authorize]

<PageTitle>Feed</PageTitle>

<h3 class="app-page-title">Feed</h3>
<p class="app-muted">Share a post with photos and browse posts from other users.</p>

@if (!string.IsNullOrWhiteSpace(_composeError))
{
    <div class="alert alert-danger" role="alert">@_composeError</div>
}

<div class="app-card p-3 mb-3">
    <EditForm EditContext="_composeEditContext" OnSubmit="CreatePost">
        <div class="form-floating">
            <InputTextArea @bind-Value="_compose.Text" class="form-control" style="min-height: 100px" placeholder="What's on your mind?" />
            <label>Write something...</label>
        </div>

        <div class="d-flex align-items-center justify-content-between gap-2 mt-3 flex-wrap">
            <div class="d-flex align-items-center gap-2">
                <InputFile OnChange="OnFilesSelected" multiple accept="image/*" />
                @if (_compose.Files.Count > 0)
                {
                    <span class="app-muted small">Selected: @_compose.Files.Count</span>
                }
            </div>
            <button class="btn btn-primary px-4" type="submit" disabled="@_posting">
                @(_posting ? "Posting..." : "Post")
            </button>
        </div>
    </EditForm>
</div>

@if (_loading)
{
    <div class="app-muted">Loading feed...</div>
}
else if (_feed.Count == 0)
{
    <div class="app-muted">No posts yet. Be the first to post.</div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var post in _feed)
        {
            <PostCard Post="post" />
        }
    </div>
}

@code {
    private ApplicationUser? _me;

    private bool _loading = true;
    private bool _posting = false;
    private string? _composeError;
    private EditContext _composeEditContext = default!;
    private ComposeModel _compose = new();

    private List<PostDto> _feed = new();

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _composeEditContext = new(_compose);

        var authState = await AuthenticationStateTask;
        _me = await UserManager.GetUserAsync(authState.User);
        if (_me is null)
        {
            NavigationManager.NavigateTo("/auth/login");
            return;
        }

        await ReloadFeed();
    }

    private async Task ReloadFeed()
    {
        _loading = true;
        _feed = await PostService.GetFeed(limit: 25, offset: 0);
        _loading = false;
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        _compose.Files = e.GetMultipleFiles(6).ToList();
    }

    private async Task CreatePost()
    {
        if (_posting || _me is null)
            return;

        _composeError = null;

        var text = (_compose.Text ?? "").Trim();
        if (text.Length == 0 && _compose.Files.Count == 0)
        {
            _composeError = "Write some text or attach at least one photo.";
            return;
        }

        if (text.Length > 2048)
        {
            _composeError = "Text is too long (max 2048).";
            return;
        }

        _posting = true;
        try
        {
            var photos = await PostMediaStorage.SavePostImages(_compose.Files);
            var created = await PostService.CreatePost(_me.Id, text, photos);
            _feed.Insert(0, created);

            _compose.Text = "";
            _compose.Files = new();
            _composeEditContext = new(_compose);
        }
        catch (Exception ex)
        {
            _composeError = ex.Message;
        }
        finally
        {
            _posting = false;
        }
    }

    private sealed class ComposeModel
    {
        public string? Text { get; set; } = "";
        public List<IBrowserFile> Files { get; set; } = new();
    }
}

