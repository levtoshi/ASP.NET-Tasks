@page "/u/{Nickname}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using TarasMessanger.Core.DTOs.Posts
@using TarasMessanger.Services
@using TarasMessanger.Storage.Identity
@using TarasMessanger.web.Components.UiComponents.Posts

@rendermode InteractiveServer

@inject UserManager<ApplicationUser> UserManager;
@inject NavigationManager NavigationManager;
@inject PostService PostService;

@attribute [Authorize]

<PageTitle>@(Nickname ?? "Profile")</PageTitle>

@if (_loading)
{
    <div class="app-muted">Loading...</div>
}
else if (_user is null)
{
    <div class="alert alert-warning" role="alert">User not found.</div>
    <a class="btn btn-outline-secondary" href="/users">Back to search</a>
}
else
{
	<h3 class="app-page-title">@_user.Nickname</h3>

    <div class="app-card p-3">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
            <div>
                <div class="app-muted small">Email</div>
                <div>@_user.Email</div>
                <div class="app-muted small mt-2">UserId</div>
                <div class="small">@_user.Id</div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" href="/users">Find users</a>
                <a class="btn btn-outline-secondary" href="/chats">Chats</a>
            </div>
        </div>
	</div>

    <div class="mt-3">
        <h4 class="mb-2">Posts</h4>
        @if (_loadingPosts)
        {
            <div class="app-muted">Loading...</div>
        }
        else if (_posts.Count == 0)
        {
            <div class="app-muted">No posts yet.</div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var post in _posts)
                {
                    <PostCard Post="post" />
                }
            </div>
        }
    </div>
}

@code {
	[Parameter] public string? Nickname { get; set; }

	private bool _loading = true;
	private ApplicationUser? _user;
    private bool _loadingPosts = true;
    private List<PostDto> _posts = new();

	protected override async Task OnParametersSetAsync()
	{
		_loading = true;
		_user = null;
        _loadingPosts = true;
        _posts = new();

        var nickname = (Nickname ?? "").Trim();
        if (nickname.Length == 0)
        {
            _loading = false;
            return;
        }

		// Username equals nickname (see Register.razor).
		_user = await UserManager.FindByNameAsync(nickname);
        if (_user is not null)
        {
            _posts = await PostService.GetUserPosts(_user.Id, limit: 25, offset: 0);
            _loadingPosts = false;
        }

        _loading = false;
	}
}
