@page "/users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using TarasMessanger.Services
@using TarasMessanger.Storage.Identity

@rendermode InteractiveServer

@inject UserManager<ApplicationUser> UserManager;
@inject PrivateChatService PrivateChatService;
@inject NavigationManager NavigationManager;

@attribute [Authorize]

<h3 class="app-page-title">User Search</h3>
<p class="app-muted">Find users by nickname and start a chat or open their profile.</p>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

<EditForm EditContext="_editContext" OnValidSubmit="Search" class="d-flex gap-2 align-items-center">
    <DataAnnotationsValidator />

    <InputText @bind-Value="_input.Query"
               id="Input.Query"
               class="form-control"
               placeholder="Type nickname (e.g. taras)" />

    <button class="btn btn-primary px-4" type="submit">Search</button>
</EditForm>

@if (_results is not null)
{
    <div class="mt-3">
        @if (_results.Count == 0)
        {
            <div class="app-muted">No users found.</div>
        }
        else
        {
            <div class="list-group">
                @foreach (var u in _results)
                {
                    <div class="list-group-item d-flex align-items-center justify-content-between gap-2">
                        <div class="d-flex flex-column">
                            <div class="fw-bold">@u.Nickname</div>
                            <div class="small app-muted">@u.Email</div>
                        </div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-secondary btn-sm" href="/u/@u.Nickname">Profile</a>
                            <button class="btn btn-primary btn-sm" @onclick="() => StartChat(u.Id)">Chat</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private ApplicationUser? _currentUser;
    private InputModel _input = new();
    private EditContext _editContext = default!;
    private List<UserListItem>? _results;
    private string? _error;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _editContext = new(_input);

        var authState = await AuthenticationStateTask;
        _currentUser = await UserManager.GetUserAsync(authState.User);
        if (_currentUser is null)
        {
            NavigationManager.NavigateTo("/auth/login");
            return;
        }
    }

    private async Task Search()
    {
        _error = null;
        _results = new();

        var query = (_input.Query ?? "").Trim();
        if (query.Length < 2)
        {
            _error = "Enter at least 2 characters.";
            return;
        }

        _results = await UserManager.Users
            .AsNoTracking()
            .Where(u => u.Id != _currentUser!.Id)
            .Where(u => u.Nickname != null && u.Nickname.Contains(query))
            .OrderBy(u => u.Nickname)
            .Take(25)
            .Select(u => new UserListItem
            {
                Id = u.Id,
                Nickname = u.Nickname!,
                Email = u.Email ?? ""
            })
            .ToListAsync();
    }

    private async Task StartChat(string otherUserId)
    {
        _error = null;
        if (_currentUser is null)
            return;

        try
        {
            var newChat = await PrivateChatService.CreateNewPrivateChat(_currentUser.Id, otherUserId);
            NavigationManager.NavigateTo($"/private/chat/{newChat.Id}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(64)]
        public string? Query { get; set; }
    }

    private sealed class UserListItem
    {
        public string Id { get; set; } = "";
        public string Nickname { get; set; } = "";
        public string Email { get; set; } = "";
    }
}

