@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a class="app-brand" href="/">TarasMessanger</a>
            <div class="top-row-spacer"></div>

            <AuthorizeView>
                <a class="top-link" href="/me">@context.User.Identity?.Name</a>
                <a class="top-link" href="/auth/logout">Logout</a>
            </AuthorizeView>
            <AuthorizeView>
                <NotAuthorized>
                    <a class="top-link" href="/auth/login">Login</a>
                    <a class="top-link" href="/auth/register">Register</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
